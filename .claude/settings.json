{
  "permissions": {
    "deny": [
      "Edit(packages/api-types/types/**)",
      "Edit(**/routeTree.gen.ts)",
      "Edit(**/__generated__/**)",
      "Edit(apps/docs/features/docs/generated/**)",
      "Edit(apps/www/.generated/**)",
      "Edit(supabase/functions/common/database-types.ts)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/install_pkgs.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/format_and_lint.sh",
            "statusMessage": "Formatting & linting..."
          }
        ]
      }
    ]
  }
}
